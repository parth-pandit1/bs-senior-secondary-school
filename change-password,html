 <!DOCTYPE html>
<html>
<head>
  <title>Change Admin Password</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f4f4;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }

    .box {
      background: white;
      padding: 30px;
      border-radius: 16px;
      box-shadow: 0 0 20px #001c3d;
      width: 350px;
      text-align: center;
    }

    input, button {
      width: 100%;
      padding: 12px;
      margin: 10px 0;
      font-size: 1rem;
      border-radius: 8px;
      border: 1px solid #ccc;
    }

    button {
      background: #004e92;
      color: white;
      font-weight: bold;
      cursor: pointer;
    }

    #msg {
      color: red;
      font-size: 0.95rem;
    }
  </style>
</head>
<body>

<div class="box">
  <h2>Change Admin Password</h2>
  <input type="password" id="currentPass" placeholder="Current Password">
  <input type="password" id="newPass" placeholder="New Password">
  <p id="msg"></p>
  <button onclick="changePassword()">Update Password</button><br>
  <button onclick="logout()">Logout</button>
</div>

<script>
  if (!localStorage.getItem("adminLoggedIn")) {
    window.location.href = "admin-login.html";
  }

  function changePassword() {
    const current = document.getElementById("currentPass").value;
    const newpass = document.getElementById("newPass").value;
    const saved = localStorage.getItem("adminPassword");

    if (current !== saved) {
      document.getElementById("msg").innerText = "Incorrect current password.";
    } else if (newpass.length < 4) {
      document.getElementById("msg").innerText = "New password too short.";
    } else {
      localStorage.setItem("adminPassword", newpass);
      alert("Password updated successfully!");
      window.location.href = "admin.html";
    }
  }

  function logout() {
    localStorage.removeItem("adminLoggedIn");
    window.location.href = "admin-login.html";
  }
</script>

</body>
</html>
